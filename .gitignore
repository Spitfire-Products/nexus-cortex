# Dependencies
node_modules/
packages/*/node_modules/

# Build artifacts
dist/
packages/*/dist/
**/*.tsbuildinfo

# Environment files — your real secrets (API keys, CLAUDE_CODE_OAUTH_TOKEN) live in
# .env, which is ignored so it is never committed. The tracked template is .env.example;
# copy it to .env and fill it in. (Prefer ~/.claude/.credentials.json for Claude OAuth.)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
.directory

# Temporary files
/tmp/
.tmp/
*.tmp

# Test coverage
coverage/
.nyc_output/

# ── .cortex/ RUNTIME — never committed. Per-cwd; **/-anchored so it also covers
#    .cortex/ folders created when cortex is launched from a subdir/package.
#    CONFIG stays tracked: CORTEX.md, MEMORY.md, config.json, agents/, commands/,
#    system-messages/, permissions*.json, bench/tasks/.
**/.cortex/sessions/
**/.cortex/test-sessions/
**/.cortex/checkpoints/
**/.cortex/file-history/
**/.cortex/artifacts/
**/.cortex/tmux-sessions/
**/.cortex/training/
**/.cortex/decisions.jsonl
**/.cortex/router-matrix.jsonl
**/.cortex/experiments.jsonl
**/.cortex/research-backlog.jsonl
# Benchmark scratch — ignore run results, KEEP the sample task set
**/.cortex/bench/*
!**/.cortex/bench/tasks/

# Stale xAI debug/event capture dumps
**/xai-*.json
**/xai-raw-http-results.json

# Cache
.cache/
.npm/

# Lock files (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
**/.addon-tools/
