# Nexus Cortex — Complete Environment Configuration Reference
# Copy to .env and fill in API keys. All other values have proven-optimal defaults.
#
# WARNING: The Settings Configurator (/config) regenerates .env from SettingsSchema.
# Runtime-only vars (OMNICLAUDE_MODE, CORTEX_*, WEB_TOOLS_MODEL, etc.) are NOT in
# the schema — they will be silently dropped unless the SettingsWriter preserves them.

# ============================================
# API KEYS
# ============================================

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
# Inception Labs (Mercury diffusion models — mercury-2)
INCEPTION_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Alibaba Qwen (DashScope) — qwen-* models
DASHSCOPE_API_KEY=
# MiniMax — minimax-* models
MINIMAX_API_KEY=
# Moonshot AI (Kimi) — moonshot-* / kimi-* models
MOONSHOT_API_KEY=
# Zhipu AI (GLM) — glm-* models
ZHIPU_API_KEY=
# Hugging Face Inference (HUGGINGFACE_TOKEN is also accepted as an alias)
HUGGINGFACE_API_KEY=

# Options: auto, oauth, api-key
ANTHROPIC_AUTH_METHOD=api-key
CLAUDE_CODE_OAUTH_TOKEN=

# ============================================
# MODEL CONFIGURATION
# ============================================

DEFAULT_MODEL_ID=deepseek-v4-pro
HELPER_MODEL_ID=deepseek-v4-flash

# Model for WebSearch/WebFetch. Auto-detects provider from ID prefix.
# Gemini options: gemini-2.5-flash (default), gemini-3.5-flash, gemini-2.5-flash-lite, gemini-3.1-pro-preview
# Other: claude-haiku-4-5, grok-4-fast-non-reasoning, grok-4.3
WEB_TOOLS_MODEL=gemini-2.5-flash

# ============================================
# SYSTEM SETTINGS
# ============================================

DEBUG=false
USE_EMOJI=false
PROJECT_PATH=

# ============================================
# REACTIVE MENTORSHIP
# ============================================

MENTORSHIP_ENABLED=false
MENTORSHIP_TRIGGER_ON_ERROR=false
MENTORSHIP_ERROR_THRESHOLD=medium
MENTORSHIP_KEYWORDS_ENABLED=false
MENTORSHIP_CUSTOM_KEYWORDS=
MENTORSHIP_HELPER_MODEL=@cf/google/gemma-4-26b-a4b-it
MENTORSHIP_TURN_BASED_ENABLED=false
MENTORSHIP_TURN_INTERVAL=10
MENTORSHIP_INTERLEAVED_THINKING=false
MENTORSHIP_PATTERN_DETECTION=false
MENTORSHIP_PATTERN_THRESHOLD=3
TURN_SUMMARY_PREDICTION=false

# ============================================
# CONTEXT MANAGEMENT
# ============================================

ANTHROPIC_PROMPT_CACHING=true
# Options: sliding-window, priority-based
CONTEXT_BUDGET_STRATEGY=priority-based

# ============================================
# SESSION CONFIGURATION
# ============================================

SESSION_STORAGE_DIR=.cortex/sessions
MCP_AUTO_INJECT=false
SYSTEM_MESSAGE_DOC_MAX_BYTES=0

# ============================================
# LOOP CONTROL
# ============================================

MAX_TOOL_ITERATIONS=50
MAX_CONSECUTIVE_ERRORS=3
TOOL_BUDGET_SOFT=15
TOOL_TIMEOUT_MS=120000
MAX_LOOP_REPETITIONS=5

# ============================================
# XAI SERVER-SIDE TOOLS
# ============================================

# R37/R38: hybrid is 20-26% faster than client-only
ENABLE_SERVER_SIDE_TOOLS=true
# Options: messages | responses
XAI_API_MODE=messages

# ============================================
# DEFERRED TOOL LOADING (R43)
# ============================================

# R43: 77% input token reduction on first turn
ENABLE_DEFERRED_TOOL_LOADING=true

# ============================================
# MODEL ROUTER
# ============================================

MODEL_ROUTER_ENABLED=false
MODEL_ROUTER_STRATEGY=auto
MODEL_ROUTER_RECORD=true
# Comma-separated model IDs the router must NEVER auto-select (cost/policy bans).
# An entry ending in '*' is a prefix wildcard. Default bans all xAI models.
MODEL_ROUTER_EXCLUDE=grok*
# Opt-in explore/exploit posterior sampling for model='auto' (default = greedy pick).
MODEL_ROUTER_EXPLORATION=false
# Min task-classification confidence (0-1) before 'auto' routes; below it, inherit parent model.
ROUTER_MIN_CONFIDENCE=0.3
# Min benchmark samples a task type needs before 'auto' trusts its matrix recommendation.
ROUTER_MIN_SAMPLES=3

# ============================================
# END-OF-TURN AUDIT / TRAINING SUBSTRATE (opt-in)
# ============================================

# Default OFF. ON = graded training records + mandatory EndTurn self-audit.
CORTEX_ENDTURN_GATE=false

# ============================================
# DECISION STORE (prior-recall + recording)
# ============================================

# Both default ON. Set to "false" to disable.
CORTEX_RECORD_DECISIONS=true
CORTEX_LOOKUP_PRIOR_DECISIONS=true
# Self-rotates at this byte cap (default 2 MB)
CORTEX_DECISIONS_MAX_BYTES=2097152
# Per-turn "Repository State" harness-note: git branch/status/recent commits +
# cross-agent staleness warnings (read-then-externally-changed files). Lets two
# agents share one working tree safely. Default ON; set "false" to disable.
CORTEX_GIT_CONTEXT=true

# ============================================
# ORCHESTRATOR MODE
# ============================================

# persistent (default) | stateless (clean per request) | server
# CORTEX_MODE is canonical; OMNICLAUDE_MODE is a legacy fallback alias.
CORTEX_MODE=persistent
# Server URL when CORTEX_MODE=server (HTTP client mode)
CORTEX_SERVER_URL=http://localhost:4000

# ============================================
# AGENT WORKSPACE
# ============================================

# tmux visual monitoring for parallel agent teams (one live pane per agent).
AGENT_TMUX_MONITOR=false

# ============================================
# TESTING
# ============================================

ENABLE_SMOKE_TESTS=false

# ============================================
# DEBUG FLAGS
# ============================================

DEBUG_PAYLOAD=false
# Verbose system-message assembly logging (also enabled by DEBUG=true).
DEBUG_SYSTEM_MESSAGES=false
# Show thinking/reasoning content in CLI. For Anthropic Opus 4.7/4.8 (adaptive
# thinking) 'true' requests display:'summarized', which BILLS extra output tokens;
# 'false' keeps reasoning omitted ($0). Other providers stream reasoning free.
DEBUG_THINKING=false

# ============================================
# RUNTIME FLAGS
# ============================================

YOLO=false
AUTO_RESUME=false
PORT=4000
# Auto-shutdown the HTTP server after N seconds idle (0 = never)
SERVER_IDLE_TIMEOUT=0
OPENAI_API_MODE=
ENABLE_PTC=false
ENABLE_LOCAL_CODE_EXECUTION=false
MENTORSHIP_ACTIVE_DISCOVERY=false
