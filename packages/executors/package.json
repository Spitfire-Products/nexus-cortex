{
  "name": "@nexus-cortex/executors",
  "version": "4.35.0",
  "description": "Tool execution layer for Nexus Cortex",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./base": {
      "import": "./dist/base/index.js",
      "types": "./dist/base/index.d.ts"
    },
    "./implementations": {
      "import": "./dist/implementations/index.js",
      "types": "./dist/implementations/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/implementations/addon && cp src/implementations/addon/terminal-client.html dist/implementations/addon/terminal-client.html",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.27.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@nexus-cortex/core": "^4.34.8",
    "@nexus-cortex/types": "^4.34.8",
    "@types/diff": "^7.0.2",
    "ajv": "^8.12.0",
    "diff": "^8.0.2",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "html-to-text": "^9.0.5",
    "playwright": "^1.56.1",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "cortex",
    "tool-execution",
    "ai-tools"
  ],
  "author": "Cortex Team",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spitfire-Products/nexus-cortex.git",
    "directory": "packages/executors"
  },
  "homepage": "https://github.com/Spitfire-Products/nexus-cortex#readme",
  "bugs": {
    "url": "https://github.com/Spitfire-Products/nexus-cortex/issues"
  },
  "optionalDependencies": {
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
