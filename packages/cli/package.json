{
  "name": "@nexus-cortex/cli",
  "version": "4.33.0",
  "description": "Nexus Cortex CLI - Terminal interface for multi-provider LLM orchestration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "cortex": "./bin/cortex.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:build": "tsc --watch",
    "dev:chat": "tsx src/index.ts chat",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prepack": "node ../../scripts/copy-pkg-cortex-scaffold.mjs"
  },
  "dependencies": {
    "@nexus-cortex/core": "^4.33.0",
    "chalk": "^4.1.2",
    "cli-spinners": "^2.9.0",
    "commander": "^11.0.0",
    "cosmiconfig": "^9.0.0",
    "diff": "^8.0.2",
    "dotenv": "^17.2.3",
    "highlight.js": "^11.9.0",
    "inquirer": "^9.2.12",
    "marked-terminal": "^6.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spitfire-Products/nexus-cortex.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "llm",
    "ai",
    "claude",
    "gpt",
    "gemini",
    "terminal",
    "cortex"
  ],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Spitfire-Products/nexus-cortex/issues"
  },
  "homepage": "https://github.com/Spitfire-Products/nexus-cortex#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".cortex",
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs"
  ]
}
